# EchoProfile Docker/WebUI settings

# Browser port on the host. docker-compose.yml binds it to 127.0.0.1 by default.
ECHOPROFILE_PORT=3727

# Recommended for remote use. Open:
# http://127.0.0.1:3727/?token=change-me
ECHOPROFILE_TOKEN=change-me

# Optional provider data directories on the host.
# Override these on Linux servers if the defaults differ.
# CLAUDE_HOME=/home/you/.claude
# CODEX_HOME=/home/you/.codex
# OPENCODE_HOME=/home/you/.local/share/opencode

# Optional build proxy for npm/apt inside Docker build stages.
# PROXY_URL=http://host.docker.internal:<port>
